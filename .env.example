# NexTopUp Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=nextopup

# Application Configuration
APP_NAME=NexTopUp
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/NexTopup-Web

# API Configuration
API_BASE_URL=http://localhost/NexTopup-Web/api

# Security
SESSION_SECRET=your-secret-key-here
JWT_SECRET=your-jwt-secret-here

# Payment Gateway (for future integration)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Email Configuration (for future integration)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@nextopup.id
MAIL_FROM_NAME=NexTopUp

# WhatsApp Business API (for customer support)
WHATSAPP_NUMBER=6281234567890
WHATSAPP_API_KEY=

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
